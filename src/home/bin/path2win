#!/bin/bash
#
# Comando: path2win
# Descrição: Converte caminho POSIX (/c/…) para Windows (C:\...)
# Uso: path2win <path>
# ==========================================================================================

if [[ "$1" =~ ^/([a-zA-Z])/(.*) ]]; then
    echo "${BASH_REMATCH[1]^^}:\\${BASH_REMATCH[2]//\//\\}"
fi
