#!/bin/bash
# Projeto: bashrc-for-devs
#
# Comando: urldecode
# Descrição: URL-decode a string fornecida.
# Uso: urldecode <string>
# =============================================================================================

urldecode() {
    local url_encoded="${1//+/ }"
    printf '%b' "${url_encoded//%/\\x}"
}

#----------------------------------------------------------------------------------------------
#--- Final do script urldecode
#----------------------------------------------------------------------------------------------