#!/bin/bash
#
# Comando: path2lin
# Descrição: Converte caminho Windows (C:\...) para POSIX (/c/...)
# Uso: path2lin <path>
# ==========================================================================================

if [[ "$1" =~ ^([A-Za-z]):\\(.*) ]]; then
    drive="${BASH_REMATCH[1],,}"
    rest="${BASH_REMATCH[2]//\\//}"
    echo "/${drive}/${rest}"
    unset drive rest
fi
