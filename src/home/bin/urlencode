#!/bin/bash
#
# Comando: urlencode
# Descrição: URL-encode a string fornecida.
# Uso: urlencode <string>
# ==========================================================================================

urlencode() {
    local length="${#1}"
    echo $length
    for (( i = 0; i < length; i++ )); do
        local c="${1:i:1}"
        case $c in
            [a-zA-Z0-9.~_-]) printf "$c";;
            *) printf '%%%02X' "'$c";;
        esac
    done
}
