[core]
    # autocrlf = input: No "commit", converte CRLF para LF. No "checkout", mantém como está (LF).
    # Isso garante que o final de linha em arquivos no servidor (repositório) sempre será LF.
    autocrlf = input

    # eol = lf: Define que, por padrão, o fim de linha nos arquivos de texto deve ser LF (padrão Unix).
    # Evita o erro comum de scripts Bash falharem no Windows por causa de caracteres invisíveis (\r).
    eol = lf

[gui]
    # encoding = utf-8: Garante que caracteres especiais (acentos) apareçam corretamente 
    # nas ferramentas visuais do Git (como Git GUI ou Gitk).
    encoding = utf-8

[http]
    # sslbackend = schannel: Instruí o Git a usar a biblioteca de segurança nativa do Windows (Schannel).
    # Isso permite que o Git use os certificados de segurança da sua empresa/Windows automaticamente.
    sslbackend = schannel

[i18n]
    # commitEncoding = utf-8: garante que o texto das mensagens de commit sejam interpretdas como UTF-8.
    commitEncoding = utf-8

    # logOutputEncoding = utf-8: garante que o texto das mensagens de log sejam interpretdas como UTF-8.
    logOutputEncoding = utf-8
