#!/bin/bash
#
# Comando: git-config
# Descrição: Configurações globais do Git (nome e email, e alguns parâmetros básicos)
# Uso: git-config
# Nota: Projetado para uso interativo; aborta em ambientes não interativos.
# ==========================================================================================

# Source das funções de display
if [ -f "${HOME}/.config/bash/00-bash-functions.sh" ]; then
    source "${HOME}/.config/bash/00-bash-functions.sh"
else
    displayAction() { echo ">>> $*"; }
    displaySuccess() { echo "[SUCCESS] $*"; }
    displayFailure() { echo "[FAILURE] $*"; }
fi

# Verificar se estamos em ambiente interativo
if [ ! -t 0 ]; then
    displayFailure "Erro" "Esse comando deve ser executado em um terminal interativo."
    exit 1
fi

displayAction "Configurações do Git"

read -p " - Nome completo .........: " name
read -p " - Endereço de email .....: " email

git config set --global user.name "$name"
git config set --global user.email "$email"
git config set --global core.autocrlf "false"
git config set --global core.eol "lf"
git config set --global gui.encoding "utf-8"
git config set --global http.sslbackend "schannel"
git config set --global i18n.commitencoding "utf-8"
git config set --global i18n.logoutputencoding "utf-8"

displaySuccess "Sucesso" "Configurações globais aplicadas com sucesso!"

# Chama git-info para exibir o resultado
git-info
